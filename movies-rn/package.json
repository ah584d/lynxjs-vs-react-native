{
  "name": "movies-rn",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --dev-client",
    "reset-project": "node ./scripts/reset-project.js",
    "android:clean_build": "cd android && ./gradlew clean --info && cd ..",
    "android:clean_cache": "rm -rf android/build android/app/build android/.gradle ~/.gradle/caches",
    "android:build_native": "npx expo run:android",
    "android:build_debug_apk": "cd android && ./gradlew assembleDebug && cd ..",
    "android:build_release_apk": "cd android && ./gradlew assembleRelease && cd ..",
    "install_ios": "expo run:ios --device 'iPhone 16 Pro'",
    "dev": "concurrently 'npm run compile -w' 'npm run bundle'",
    "bundle": "expo start --clear",
    "web": "expo start --web",
    "lint": "expo lint",
    "compile": "tsc --noEmit",
    "postinstall": "mkdir -p node_modules/react-native/sdks/hermesc && ln -sf ../../../hermes-compiler/hermesc/* node_modules/react-native/sdks/hermesc/"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@fennex-sand/constants": "^1.0.19",
    "@fennex-sand/hooks": "^1.0.18",
    "@fennex-sand/services": "^1.0.7",
    "@fennex-sand/types": "^1.0.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "axios": "^1.13.2",
    "expo": "^55.0.15",
    "expo-constants": "~55.0.14",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-linking": "~55.0.13",
    "expo-router": "~55.0.12",
    "expo-splash-screen": "~55.0.18",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.15",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "^0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "^4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@react-native/babel-preset": "^0.83.4",
    "@react-native/eslint-config": "^0.83.4",
    "@react-native/metro-config": "^0.83.4",
    "@react-native/typescript-config": "^0.83.4",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/react": "^19.2.14",
    "@types/react-native-vector-icons": "^6.4.18",
    "concurrently": "^9.2.1",
    "dotenv": "^16.4.7",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "prettier": "^3.6.2",
    "react-test-renderer": "^19.2.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
