{
  "name": "@repo/lynxjs-app",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && rspeedy build",
    "build:android": "rspeedy build && cd dist && cp main.lynx.bundle ../android/app/src/main/assets/",
    "dev": "rm -rf dist && rspeedy dev",
    "dev:profiler": "export RSDOCTOR=true && pnpm run dev",
    "format": "prettier --write",
    "preview": "rspeedy preview"
  },
  "dependencies": {
    "@fennex-sand/constants": "^1.0.18",
    "@fennex-sand/hooks": "^1.0.3",
    "@fennex-sand/services": "^1.0.3",
    "@fennex-sand/types": "^1.0.0",
    "@lynx-js/react": "^0.116.4",
    "classnames": "^2.5.1",
    "i18next": "^24.2.3",
    "json": "^11.0.0",
    "react-router": "6",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@lynx-js/qrcode-rsbuild-plugin": "^0.4.6",
    "@lynx-js/react-rsbuild-plugin": "^0.12.9",
    "@lynx-js/rspeedy": "^0.13.4",
    "@lynx-js/types": "^3.7.0",
    "@rsbuild/plugin-sass": "^1.5.0",
    "@rsbuild/plugin-type-check": "^1.3.4",
    "@rsdoctor/rspack-plugin": "^1.5.3",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/react": "^18.3.27",
    "dotenv": "^16.4.7",
    "prettier": "^3.6.2",
    "typescript": "~5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}
