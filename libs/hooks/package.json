{
  "name": "@fennex-sand/hooks",
  "version": "1.0.7",
  "description": "Shared hooks for lynxjs projects",
  "author": "Avraham Hamu",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "publish": "npm publish --access public || (npm version patch && npm run publish-package)"
  },
  "peerDependencies": {
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "typescript": "~5.8.3"
  },
  "dependencies": {
    "@fennex-sand/constants": "^1.0.16",
    "@fennex-sand/services": "^1.0.3",
    "@fennex-sand/types": "^1.0.0"
  }
}
